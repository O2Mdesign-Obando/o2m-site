---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "O2M Design | Product Design & UX/UI in New Jersey";
const description = "Product design, UX/UI, and digital experience design for businesses in New Jersey. O2M Design helps companies build clear, scalable digital products.";
---

<BaseLayout title={title} description={description}>
  <section class="hero">
    <div class="eyebrow">Product Design · UX/UI · Systems Thinking</div>

    <h1>
      Clear, structured digital experiences
      that help businesses build and scale.
    </h1>

    <p>
      I work with businesses and growing teams to design products, improve UX,
      and bring clarity to complex digital systems.
    </p>

    <p>
      <a href="mailto:connect@o2mdesign.com">Start a conversation →</a>
    </p>

    <p>
      <a href="/services">See how I work →</a>
    </p>
  </section>

  <section class="section">
    <h2>What I Do</h2>
    <p>
      I help businesses understand their users, structure their digital systems,
      and design experiences that work in the real world — from early discovery
      to final execution.
    </p>
  </section>

  <section class="section">
    <h2>A Local, Hands-On Partner</h2>
    <p>
      I work directly with clients as a hands-on design partner — not as a distant agency.
      This means clear communication, practical solutions, and close collaboration.
    </p>
  </section>

  <section class="section">
    <h2>Services</h2>

    <div class="grid">
      <a class="card card-link" href="/services">
        <strong>Product Design</strong>
        <p>End-to-end product design focused on usability and scalability.</p>
      </a>

      <a class="card card-link" href="/services">
        <strong>UX/UI Design</strong>
        <p>Clear, intuitive interfaces grounded in real user behavior.</p>
      </a>

      <a class="card card-link" href="/services">
        <strong>Systems Thinking</strong>
        <p>Designing connected systems — not isolated screens.</p>
      </a>
    </div>

    <p>
      <a href="/services">Explore services and approach →</a>
    </p>
  </section>

  <section class="section">
    <h2>Selected Clients</h2>
    <p>
      Selected collaborations across enterprise, finance, healthcare, and technology.
    </p>
    <p>
      Work includes enterprise platforms, customer-facing products, and complex internal systems.
    </p>

    <div class="logo-grid">
      <img src="/logos/amazon.png" alt="Amazon" />
      <img src="/logos/ibm.png" alt="IBM" />
      <img src="/logos/american-express.png" alt="American Express" />
      <img src="/logos/audible.png" alt="Audible" />
      <img src="/logos/novartis.png" alt="Novartis" />
      <img src="/logos/wells-fargo.png" alt="Wells Fargo" />
      <img src="/logos/t-rowe-price.png" alt="T. Rowe Price" />
      <img src="/logos/ab-inbev.png" alt="AB InBev" />
      <img src="/logos/saama.png" alt="Saama" />
      <img src="/logos/boehringer-ingelheim.png" alt="Boehringer Ingelheim" />
      <img src="/logos/medidata.jpg" alt="Medidata" />
      <img src="/logos/wolters-kluwer.png" alt="Wolters Kluwer" />
    </div>
  </section>

  <section class="section">
    <h2>Published Work</h2>

    <div class="grid">
      <a class="card card-link" href="https://whatremains.info" target="_blank">
        <strong>What Remains</strong>
        <p>A reflective exploration of memory and presence.</p>
      </a>

      <a class="card card-link" href="https://thetracksremember.com" target="_blank">
        <strong>The Tracks Remember</strong>
        <p>A story of travel, family, and lasting moments.</p>
      </a>

      <a class="card card-link" href="https://trainsandcastles.com" target="_blank">
        <strong>Trains and Castles</strong>
        <p>A companion story for younger readers.</p>
      </a>
    </div>
  </section>

  <section class="contact-block">
    <div class="contact-inner">
      <h2>Contact</h2>
      <p>
        If you're working on a product, a redesign, or something that feels unclear or fragmented —
        I can help bring structure and clarity to it.
      </p>

      <p>Typical response time: within 24 hours</p>

      <p>
        <a href="mailto:connect@o2mdesign.com">connect@o2mdesign.com</a><br />
        <a href="https://www.linkedin.com/company/o2m-design" target="_blank">LinkedIn</a>
      </p>

      <p>
        Based in New Jersey · Available for local and remote work
      </p>
    </div>
  </section>
</BaseLayout>