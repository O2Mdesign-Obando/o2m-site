---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "About | O2M Design";
const description = "About Jorge R. Obando and O2M Design.";
---

<BaseLayout title={title} description={description}>
  <section class="hero">
    <h1>About</h1>
  </section>

  <section class="section">
    <p>
      Jorge R. Obando is a product designer, systems thinker, and builder of digital experiences.
    </p>

    <p>
      With over 20 years of experience across enterprise, finance, healthcare, and media,
      his work focuses on bringing clarity to complex systems and designing experiences that are both usable and scalable.
    </p>

    <p>
      Based in New Jersey, he works directly with clients as a hands-on partner — combining strategic thinking with practical execution.
    </p>
    <p>
  <a href="https://jorgeobando.com/" target="_blank">
    View portfolio and professional archive →
  </a>
</p>
  </section>
</BaseLayout>