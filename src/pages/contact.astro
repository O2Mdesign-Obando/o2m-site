---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "O2M Design | Product Design & UX/UI in New Jersey";
const description = "Product design, UX/UI, and digital experience design for businesses in New Jersey. O2M Design helps companies build clear, scalable digital products.";
---

<BaseLayout title={title} description={description}>
  <section class="hero">
    <h1>Contact</h1>
  </section>

  <section class="section">
    <p>
      Tell me a bit about what you’re working on. I’ll get back to you shortly.
    </p>

    <p>
      <a href="mailto:connect@o2mdesign.com">connect@o2mdesign.com</a>
    </p>

    <p>
      <a href="https://www.linkedin.com/company/o2m-design" target="_blank">
        LinkedIn
      </a>
    </p>
  </section>
</BaseLayout>