---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "O2M Design | Product Design & UX/UI in New Jersey";
const description = "Product design, UX/UI, and digital experience design for businesses in New Jersey. O2M Design helps companies build clear, scalable digital products.";
---

<BaseLayout title={title} description={description}>
 <section class="hero">
  <h1>Services</h1>
  <p>
    I help businesses bring structure, clarity, and usability to their digital products — from early-stage ideas to complex, evolving systems.
  </p>
</section>

<section class="section">
  <h2>Product Design</h2>
  <p>
    End-to-end product design focused on turning ideas into usable, scalable digital products.  
    This includes structuring the product, defining core flows, and ensuring the experience supports real user behavior.
  </p>
</section>

<section class="section">
  <h2>UX/UI Design</h2>
  <p>
    Designing clear, intuitive interfaces that reduce friction and guide users toward action.  
    The focus is not just visual design, but how the experience actually works in real-world use.
  </p>
</section>

<section class="section">
  <h2>Systems Thinking</h2>
  <p>
    Bringing order to complex or fragmented products by designing connected systems instead of isolated screens.  
    This ensures consistency, scalability, and long-term maintainability.
  </p>
</section>

<section class="section">
  <h2>Prototyping & Validation</h2>
  <p>
    Rapid prototyping and testing to validate ideas before development.  
    This helps reduce risk, clarify decisions, and align teams early in the process.
  </p>
</section>

<section class="section">
  <h2>Digital Strategy</h2>
  <p>
    Experience-driven guidance to align product decisions with business goals.  
    Especially useful when a product exists but lacks clarity, direction, or cohesion.
  </p>
</section>

<section class="section">
  <h2>How I Work</h2>
  <p>
    I work directly with clients as a hands-on partner — not as a distant agency.  
    Engagements are focused, practical, and tailored to the specific stage of the product.
  </p>

  <p>
    Typical starting points include:
  </p>

  <ul>
    <li>A quick UX / product audit</li>
    <li>Improving an existing flow or interface</li>
    <li>Structuring a new product or feature</li>
  </ul>
</section>

<section class="contact-block">
  <div class="contact-inner">
    <h2>Start a Conversation</h2>
    <p>
      If you’re working on something and need clarity, structure, or a second perspective — let’s talk.
    </p>

    <p>
      Typical response time: within 24 hours
    </p>

    <p>
      <a href="mailto:connect@o2mdesign.com">connect@o2mdesign.com</a>
    </p>
  </div>
</section>
</BaseLayout>