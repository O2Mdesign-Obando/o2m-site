---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Services | O2M Design";
const description = "Product design, UX/UI, and digital strategy services.";
---

<BaseLayout title={title} description={description}>
  <section class="hero">
    <h1>Services</h1>
  </section>

  <section class="section">
    <h2>Product Design</h2>
    <p>End-to-end product design focused on usability and long-term scalability.</p>
  </section>

  <section class="section">
    <h2>UX/UI Design</h2>
    <p>Clear, intuitive interfaces grounded in user behavior and real-world interaction.</p>
  </section>

  <section class="section">
    <h2>Systems Thinking</h2>
    <p>Designing connected systems — not isolated screens — to ensure consistency.</p>
  </section>

  <section class="section">
    <h2>Prototyping & Validation</h2>
    <p>Rapid prototyping and testing to validate ideas before development.</p>
  </section>

  <section class="section">
    <h2>Digital Strategy</h2>
    <p>Experience-driven guidance to align digital products with business goals.</p>
  </section>
</BaseLayout>