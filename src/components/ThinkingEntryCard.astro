---
const { entry } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(entry.data.publishDate);
---

<article class="thinking-card">
  <div class="thinking-card__meta">
    <span>{entry.data.eyebrow}</span>
    <span>{formattedDate}</span>
  </div>

  <h3>
    <a href={`/thinking/${entry.slug}`}>
      {entry.data.title}
    </a>
  </h3>

  {entry.data.subtitle && <p class="thinking-card__subtitle">{entry.data.subtitle}</p>}

  <p>{entry.data.excerpt}</p>

  <a class="thinking-card__link" href={`/thinking/${entry.slug}`}>
    Read entry →
  </a>
</article>

<style>
  .thinking-card {
    border-top: 1px solid var(--border, #ddd);
    padding: 2rem 0;
  }

  .thinking-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted, #666);
  }

  .thinking-card h3 {
    margin: 0 0 0.75rem;
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.2;
  }

  .thinking-card h3 a {
    color: inherit;
    text-decoration: none;
  }

  .thinking-card h3 a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .thinking-card__subtitle {
    margin-bottom: 0.75rem;
    color: var(--muted, #555);
  }

  .thinking-card p {
    max-width: 42rem;
  }

  .thinking-card__link {
    display: inline-block;
    margin-top: 1rem;
  }
</style>